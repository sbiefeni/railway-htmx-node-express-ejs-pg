<div
  id="todo-<%= todo.id %>"
  class="flex items-center justify-between p-4 bg-gray-800 rounded-lg mb-2 group"
>
  <div class="flex items-center gap-3">
    <input
      type="checkbox"
      <%= todo.completed ? 'checked' : '' %>
      hx-patch="/todos/<%= todo.id %>/toggle"
      hx-target="#todo-<%= todo.id %>"
      hx-swap="outerHTML"
      class="w-5 h-5 rounded bg-gray-700 border-gray-600 cursor-pointer"
    >
    <span class="<%= todo.completed ? 'text-gray-500 line-through' : 'text-gray-100' %>">
      <%= todo.title %>
    </span>
  </div>
  <button
    hx-delete="/todos/<%= todo.id %>"
    hx-target="#todo-<%= todo.id %>"
    hx-swap="outerHTML"
    class="text-gray-500 hover:text-red-400 opacity-0 group-hover:opacity-100 transition-all cursor-pointer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
    </svg>
  </button>
</div>
